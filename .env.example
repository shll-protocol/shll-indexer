# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/ponder

# BSC Testnet RPC (Alchemy recommended for reliability)
PONDER_RPC_URL_97=https://bnb-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Optional: multiple RPC endpoints (comma-separated, used with failover)
# PONDER_RPC_URLS_97=https://bnb-testnet.g.alchemy.com/v2/YOUR_KEY,https://data-seed-prebsc-1-s1.bnbchain.org:8545

# RPC throttling for strict providers (e.g. public BNB seed nodes)
MAX_REQUESTS_PER_SECOND=1
RPC_MIN_INTERVAL_MS=1500
RPC_TIMEOUT_MS=5000
POLLING_INTERVAL_MS=10000
ETH_GET_LOGS_BLOCK_RANGE=1
