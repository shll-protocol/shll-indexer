# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/ponder

# BSC Testnet RPC (Alchemy recommended for reliability)
PONDER_RPC_URL_97=https://bnb-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
# Optional: multiple RPC endpoints (comma-separated, used with failover)
# PONDER_RPC_URLS_97=https://bnb-testnet.g.alchemy.com/v2/YOUR_KEY,https://data-seed-prebsc-1-s1.bnbchain.org:8545

# Contract addresses on BSC Testnet (V3.0)
LISTING_MANAGER_ADDRESS_97=0x5AE99B80E78D237C839b8Adad819AdAb34E00f55
AGENT_NFA_ADDRESS_97=0x882503744A91f90D3b64AC52a6d0BA42549f3FF8
POLICY_GUARD_V4_ADDRESS_97=0x0000000000000000000000000000000000000000
# BAP-578: LearningModule (Proof of Prompt)
LEARNING_MODULE_ADDRESS_97=0x019765B2669b1A3FfffE8213E9bd0b0D8eb00892
# Set to the deployment block to skip historical sync
CONTRACT_START_BLOCK_97=90773067

# RPC tuning
MAX_REQUESTS_PER_SECOND=1
RPC_MIN_INTERVAL_MS=0
RPC_TIMEOUT_MS=5000
RPC_FAILOVER_MAX_ATTEMPTS=2
RPC_FAILOVER_COOLDOWN_MS=30000
RPC_FAILOVER_FAILURE_THRESHOLD=2
POLLING_INTERVAL_MS=10000
ETH_GET_LOGS_BLOCK_RANGE=1
