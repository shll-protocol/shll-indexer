import { onchainTable, index } from "ponder";

// Listings on the marketplace
export const listing = onchainTable("listing", (t) => ({
  id: t.hex().primaryKey(),
  nfa: t.hex().notNull(),
  tokenId: t.bigint().notNull(),
  owner: t.hex().notNull(),
  pricePerDay: t.bigint().notNull(),
  minDays: t.integer().notNull(),
  active: t.boolean().notNull().default(true),
  isTemplate: t.boolean().notNull().default(false),
  renter: t.hex(),
  expires: t.bigint(),
  agentName: t.text().default("Unknown Agent"),
  createdAt: t.bigint().notNull(),
  updatedAt: t.bigint().notNull(),
}), (table) => ({
  activeIdx: index().on(table.active),
  nfaIdx: index().on(table.nfa),
  ownerIdx: index().on(table.owner),
}));

// Agents (NFTs minted)
export const agent = onchainTable("agent", (t) => ({
  id: t.text().primaryKey(),
  tokenId: t.bigint().notNull(),
  owner: t.hex().notNull(),
  account: t.hex().notNull(),
  policyId: t.hex().notNull(),
  isTemplate: t.boolean().notNull().default(false),
  templateId: t.bigint(),
  createdAt: t.bigint().notNull(),
}));

// Rental history records
export const rentalHistory = onchainTable("rental_history", (t) => ({
  id: t.text().primaryKey(),
  listingId: t.hex().notNull(),
  renter: t.hex().notNull(),
  expires: t.bigint().notNull(),
  totalPaid: t.bigint().notNull(),
  eventType: t.text().notNull(),
  timestamp: t.bigint().notNull(),
  blockNumber: t.bigint().notNull(),
}), (table) => ({
  listingIdx: index().on(table.listingId),
  renterIdx: index().on(table.renter),
}));

// Agent execution activity
export const executionHistory = onchainTable("execution_history", (t) => ({
  id: t.text().primaryKey(),
  tokenId: t.bigint().notNull(),
  caller: t.hex().notNull(),
  account: t.hex().notNull(),
  target: t.hex().notNull(),
  selector: t.hex().notNull(),
  success: t.boolean().notNull(),
  result: t.hex().notNull(),
  txHash: t.hex().notNull(),
  logIndex: t.integer().notNull(),
  blockNumber: t.bigint().notNull(),
  timestamp: t.bigint().notNull(),
}), (table) => ({
  tokenIdx: index().on(table.tokenId, table.timestamp),
  txIdx: index().on(table.txHash),
}));

// --- V1.4: Parameterized Policies ---

export const policy = onchainTable("policy", (t) => ({
  id: t.text().primaryKey(), // policyId-version
  policyId: t.integer().notNull(),
  version: t.integer().notNull(),
  creator: t.hex().notNull(),
  isFrozen: t.boolean().notNull().default(false),
  // Schema (Caps)
  maxSlippageBps: t.integer(),
  maxTradeLimit: t.bigint(),
  maxDailyLimit: t.bigint(),
  allowedTokenGroups: t.text(), // array as JSON string
  allowedDexGroups: t.text(), // array as JSON string
  receiverMustBeVault: t.boolean(),
  forbidInfiniteApprove: t.boolean(),
  createdAt: t.bigint().notNull(),
}));

export const actionRule = onchainTable("action_rule", (t) => ({
  id: t.text().primaryKey(), // policyId-version-target-selector
  policyId: t.integer().notNull(),
  version: t.integer().notNull(),
  target: t.hex().notNull(),
  selector: t.hex().notNull(),
  moduleMask: t.bigint().notNull(),
}));

export const groupMember = onchainTable("group_member", (t) => ({
  id: t.text().primaryKey(), // groupId-address
  groupId: t.integer().notNull(),
  address: t.hex().notNull(),
  active: t.boolean().notNull(),
}));

export const instanceConfig = onchainTable("instance_config", (t) => ({
  id: t.bigint().primaryKey(), // instanceId
  policyId: t.integer().notNull(),
  version: t.integer().notNull(),
  paramsPacked: t.hex().notNull(),
  // Extracted params for easy querying
  slippageBps: t.integer(),
  tradeLimit: t.bigint(),
  dailyLimit: t.bigint(),
  tokenGroupId: t.integer(),
  dexGroupId: t.integer(),
  updatedAt: t.bigint().notNull(),
}));

export const spendHistory = onchainTable("spend_history", (t) => ({
  id: t.text().primaryKey(), // txHash-logIndex
  instanceId: t.bigint().notNull(),
  amount: t.bigint().notNull(),
  dayIndex: t.integer().notNull(),
  txHash: t.hex().notNull(),
  timestamp: t.bigint().notNull(),
}), (table) => ({
  instanceIdx: index().on(table.instanceId, table.timestamp),
}));
